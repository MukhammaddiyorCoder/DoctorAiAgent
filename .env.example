# ============================================
# Doctor AI Agent - Environment Variables
# ============================================

# --- Django ---
DJANGO_SECRET_KEY=change-me-to-a-strong-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
DJANGO_SETTINGS_MODULE=config.settings.development

# --- Database (PostgreSQL) ---
POSTGRES_DB=doctor_ai
POSTGRES_USER=doctor
POSTGRES_PASSWORD=doctor_pass
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Redis / Celery / Channels ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CHANNELS_REDIS_URL=redis://redis:6379/3

# --- JWT ---
JWT_ACCESS_TOKEN_LIFETIME_MIN=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# --- CORS / Frontend ---
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Claude AI (Anthropic) ---
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# --- Email (optional) ---
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@doctor-ai.local

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000
